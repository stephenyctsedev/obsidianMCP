# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Bearer token required on every /mcp request (Authorization: Bearer <token>).
# Generate a strong one:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=replace-me-with-openssl-rand-hex-32

# Which vault subfolder inside the mounted Obsidian folder to serve.
# The active vault is /vault/<VAULT_NAME>. Leave blank to use the mount root.
VAULT_NAME=Memory

# Synology user id / group id that owns the vault, so the container can
# read/write it. Find them by SSHing into DSM and running: id stephenyctse
# Defaults (1026:100) are typical for the first DSM user; verify yours.
PUID=1026
PGID=100

# Optional LOCAL git version history of the vault. Never pushed anywhere;
# the .git folder lives in the vault (a dot-folder, so it is NOT synced to
# your devices). Set to true to enable.
GIT_VERSIONING=false
GIT_AUTHOR_NAME=obsidian-mcp
GIT_AUTHOR_EMAIL=obsidian-mcp@localhost
# Whole-vault snapshot interval in minutes (captures phone/PC edits too).
# 0 = off. 15 is a reasonable starting point.
GIT_SNAPSHOT_MINUTES=15
